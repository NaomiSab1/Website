<!-- ════════════════════════════════════════════
     ABOUT
════════════════════════════════════════════ -->
<section class="sp" id="about">
  <div class="inner about-grid">
    <div class="about-sticky">
      <div class="slabel reveal">About Sabdia</div>
      <h2 class="about-h reveal d1">Crafting <em>Exquisite</em><br>Living Spaces.</h2>
      <div class="about-img-strip reveal d2">
        <img src="https://static.wixstatic.com/media/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg/v1/fill/w_900,h_600,al_c,q_85/1cc2db_4e48586f78704fc3ae5d00ddb8a125ee~mv2.jpg" alt="Sabdia craftsmanship" loading="lazy">
        <img src="https://static.wixstatic.com/media/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg/v1/fill/w_500,h_600,al_c,q_85/1cc2db_9e730867446c414c9fe72c1549cb7261~mv2.jpg" alt="Sabdia detail" loading="lazy">
      </div>
    </div>
    <div>
      <p class="about-p reveal d2">At Sabdia, we manage every step of the residential development journey in-house — from visionary design through to expert construction. This integrated approach allows us to maintain meticulous control over quality, timing, and innovation, delivering homes that stand the test of time.</p>
      <p class="about-p reveal d2">With a focus on creating exceptional living spaces, Sabdia Constructions is dedicated to shaping the future of residential developments through innovation, quality, and unparalleled craftsmanship. Every project begins with a deep understanding of both the site and the clients who will call it home.</p>
      <p class="about-p reveal d2">We are not merely builders — we are creators of legacy. Each residence we deliver is conceived as a singular work of architecture, thoughtfully designed to complement its surroundings and exceed every expectation of luxury living.</p>
      <div class="sig reveal d3">
        <div class="sig-name">Sabdia</div>
        <div class="sig-title">Founder &amp; Principal</div>
      </div>
      <div class="about-vals reveal d4">
        <div class="about-val">
          <span class="about-val-n">i.</span>
          <div><div class="about-val-t">Integrated Delivery</div><div class="about-val-d">Design, develop, and construct under one roof — seamless from concept to keys.</div></div>
        </div>
        <div class="about-val">
          <span class="about-val-n">ii.</span>
          <div><div class="about-val-t">Uncompromising Quality</div><div class="about-val-d">Only the finest materials, master tradespeople, and meticulous attention to detail.</div></div>
        </div>
        <div class="about-val">
          <span class="about-val-n">iii.</span>
          <div><div class="about-val-t">Boutique &amp; Personal</div><div class="about-val-d">Limited projects annually to ensure every client receives our full dedication.</div></div>
        </div>
      </div>
      <div class="reveal d5" style="margin-top:40px">
        <a href="/about.html" class="btn-g">Our Full Story &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     PROPERTIES
════════════════════════════════════════════ -->
{% set forSaleProps = properties | forSale %}
{% set featuredProp = properties | featured %}
{% set soldProps = properties | sold %}

<section id="properties" style="padding:0 0 clamp(80px,12vw,160px)">
  <div class="inner" style="padding:clamp(80px,12vw,160px) clamp(22px,5vw,80px) clamp(44px,5vw,60px)">
    <div class="proj-hdr">
      <div>
        <div class="slabel reveal">For Sale</div>
        <h2 class="proj-h reveal d1"><em>Current</em> Properties</h2>
      </div>
      <a href="/properties/" class="btn-g reveal d2">View All &rarr;</a>
    </div>
  </div>

  <div class="inner" style="padding:0 clamp(22px,5vw,80px)">
    <div class="proj-grid proj-grid-main reveal">
      <!-- Featured hero card -->
      {% if featuredProp %}
      <a class="pc pc-hero" href="/properties/{{ featuredProp.slug }}/">
        <img src="{{ featuredProp.card_image }}" alt="{{ featuredProp.name }}" loading="lazy">
        <div class="pc-ov"></div>
        <div class="pc-info">
          <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
          <div class="pc-name">{{ featuredProp.name }}</div>
          <div class="pc-loc">{{ featuredProp.suburb }}, QLD</div>
          <div class="pc-specs">
            <span class="pc-spec">{{ featuredProp.bedrooms }} Bed</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ featuredProp.bathrooms }} Bath</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ featuredProp.garages }} Garage</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ featuredProp.land_size }}</span>
          </div>
        </div>
        <div class="pc-arrow">&rarr;</div>
      </a>
      {% endif %}

      <!-- Second property (top right) -->
      {% if forSaleProps[1] %}
      {% set p2 = forSaleProps[1] %}
      <a class="pc pc-sm-a" href="/properties/{{ p2.slug }}/" style="aspect-ratio:4/3">
        <img src="{{ p2.card_image }}" alt="{{ p2.name }}" loading="lazy">
        <div class="pc-ov"></div>
        <div class="pc-info">
          <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
          <div class="pc-name">{{ p2.name }}</div>
          <div class="pc-loc">{{ p2.suburb }}, QLD</div>
          <div class="pc-specs">
            <span class="pc-spec">{{ p2.bedrooms }} Bed</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p2.bathrooms }} Bath</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p2.land_size }}</span>
          </div>
        </div>
        <div class="pc-arrow">&rarr;</div>
      </a>
      {% endif %}

      <!-- Third property (bottom right) -->
      {% if forSaleProps[2] %}
      {% set p3 = forSaleProps[2] %}
      <a class="pc pc-sm-b" href="/properties/{{ p3.slug }}/" style="aspect-ratio:4/3">
        <img src="{{ p3.card_image }}" alt="{{ p3.name }}" loading="lazy">
        <div class="pc-ov"></div>
        <div class="pc-info">
          <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
          <div class="pc-name">{{ p3.name }}</div>
          <div class="pc-loc">{{ p3.suburb }}, QLD</div>
          <div class="pc-specs">
            <span class="pc-spec">{{ p3.bedrooms }} Bed</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p3.bathrooms }} Bath</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p3.land_size }}</span>
          </div>
        </div>
        <div class="pc-arrow">&rarr;</div>
      </a>
      {% endif %}
    </div>

    <!-- Bottom row: 4th for-sale + sold properties -->
    <div style="margin-top:10px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px">
      {% if forSaleProps[3] %}
      {% set p4 = forSaleProps[3] %}
      <a class="pc reveal" href="/properties/{{ p4.slug }}/" style="aspect-ratio:16/10">
        <img src="{{ p4.card_image_sm or p4.card_image }}" alt="{{ p4.name }}" loading="lazy">
        <div class="pc-ov"></div>
        <div class="pc-info">
          <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
          <div class="pc-name">{{ p4.name }}</div>
          <div class="pc-loc">{{ p4.suburb }}, QLD</div>
          <div class="pc-specs">
            <span class="pc-spec">{{ p4.bedrooms }} Bed</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p4.bathrooms }} Bath</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ p4.land_size }}</span>
          </div>
        </div>
        <div class="pc-arrow">&rarr;</div>
      </a>
      {% endif %}

      {% for soldProp in soldProps | slice(0, 2) %}
      <a class="sc-card reveal d{{ loop.index }}" href="/properties/{{ soldProp.slug }}/">
        <img src="{{ soldProp.card_image_sm or soldProp.card_image }}" alt="{{ soldProp.name }}" loading="lazy">
        <div class="sc-ov"></div>
        <div class="sc-badge">Sold Prior to Completion</div>
        <div class="sc-info">
          <div class="sc-name">{{ soldProp.name }}</div>
          <div class="sc-loc">{{ soldProp.bedrooms }} Bed &middot; {{ soldProp.bathrooms }} Bath &middot; {{ soldProp.garages }} Garage &middot; {{ soldProp.land_size }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     SERVICES (dark section)
════════════════════════════════════════════ -->
<section class="svc-dark sp" id="services">
  <div class="inner svc-layout">
    <div class="svc-sticky">
      <div class="slabel reveal">What We Do</div>
      <h2 class="svc-h reveal d1">Full-spectrum<br><em>development</em><br>expertise.</h2>
      <p class="svc-p reveal d2">From site acquisition through to final handover, Sabdia manages every element in-house — ensuring seamless delivery and uncompromising quality at every stage.</p>
      <div class="reveal d3" style="margin-top:40px">
        <a href="/services.html" class="btn-g" style="margin-top:8px">Explore Services &rarr;</a>
      </div>
    </div>
    <ul class="svc-list">
      {% for svc in services %}
      <li class="svc-item reveal{% if not loop.first %} d{{ loop.index - 1 }}{% endif %}">
        <span class="svc-n">{{ svc.number }}</span>
        <div>
          <div class="svc-t">{{ svc.title }}</div>
          <div class="svc-d">{{ svc.short_description }}</div>
        </div>
        <div class="svc-icon">
          {% if loop.index == 1 %}<svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M1 7L7 1L13 7V13H9V9H5V13H1V7Z"/></svg>
          {% elif loop.index == 2 %}<svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="3" width="12" height="10"/><path d="M4 3V1H10V3"/></svg>
          {% elif loop.index == 3 %}<svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="7" cy="7" r="5.5"/><path d="M7 4.5V7L9 9"/></svg>
          {% else %}<svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="1" y="1" width="12" height="12"/><path d="M4 7h6M7 4v6"/></svg>
          {% endif %}
        </div>
      </li>
      {% endfor %}
    </ul>
  </div>
</section>

<!-- ════════════════════════════════════════════
     PROCESS
════════════════════════════════════════════ -->
<section class="sp">
  <div class="inner">
    <div class="slabel reveal" style="margin-bottom:56px">Our Process</div>
    <div class="proc-track">
      <div class="proc-step reveal">
        <div class="proc-n">1</div>
        <div class="proc-t">Design</div>
        <div class="proc-d">Visionary design that balances beauty, functionality, and long-term value. Every project begins with a deep understanding of site, context, and client.</div>
      </div>
      <div class="proc-step reveal d1">
        <div class="proc-n">2</div>
        <div class="proc-t">Develop</div>
        <div class="proc-d">We manage the complete development process in-house — approvals, planning, engineering — maintaining full control over every decision and outcome.</div>
      </div>
      <div class="proc-step reveal d2">
        <div class="proc-n">3</div>
        <div class="proc-t">Construct</div>
        <div class="proc-d">Precision construction by our own team of master tradespeople, using premium materials and meticulous quality control at every stage of the build.</div>
      </div>
      <div class="proc-step reveal d3">
        <div class="proc-n">4</div>
        <div class="proc-t">Deliver</div>
        <div class="proc-d">Handover marks the beginning of your story. Our aftercare ensures your home continues to perform and delight for decades to come.</div>
      </div>
    </div>
  </div>
</section>

<!-- ════════════════════════════════════════════
     TESTIMONIAL (dark)
════════════════════════════════════════════ -->
{% set testi = testimonials | activeTestimonial %}
{% if testi %}
<section class="testi-dark sp">
  <div class="inner">
    <div class="testi-wrap">
      <div>
        <span class="testi-q-mark reveal">&ldquo;</span>
      </div>
      <div>
        <blockquote class="testi-text reveal d1">{{ testi.quote }}</blockquote>
        <div class="testi-auth reveal d2">
          <div class="testi-line"></div>
          <div class="testi-name">{{ testi.attribution }}</div>
        </div>
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- ════════════════════════════════════════════
     AGENT ACCESS
════════════════════════════════════════════ -->
<div class="agent-grid" id="agents">
  <div class="agent-vis reveal-x">
    <img src="https://static.wixstatic.com/media/1cc2db_7d6ddb5093af4f3eb6b9d3acd088be79~mv2.png/v1/fill/w_900,h_1100,q_85,enc_avif,quality_auto/1cc2db_7d6ddb5093af4f3eb6b9d3acd088be79~mv2.png" alt="Agent Access" loading="lazy">
    <div class="agent-frame"></div>
    <div class="agent-badge">Exclusive Access</div>
  </div>
  <div class="agent-content">
    <div class="slabel reveal">For Real Estate Professionals</div>
    <h2 class="agent-h reveal d1">Exclusive <em>Agent</em><br>Access.</h2>
    <p class="agent-p reveal d2">Gain exclusive insight into Sabdia's future releases. Our agent-only preview list offers early access to premium developments, pre-launch information, and priority communication — giving your clients an edge in Brisbane's luxury market.</p>
    <ul class="agent-feats reveal d3">
      <li>Pre-release access to upcoming developments</li>
      <li>Pre-launch pricing and floor plan information</li>
      <li>Priority communication on new releases</li>
      <li>Exclusive commission structures</li>
      <li>Invitations to private project previews</li>
      <li>Dedicated liaison with the Sabdia team</li>
    </ul>
    <div class="agent-btns reveal d4">
      <a href="/agent-access.html" class="btn-p">Apply for Access</a>
      <a href="/contact.html" class="btn-g">Learn More</a>
    </div>
  </div>
</div>

<!-- ════════════════════════════════════════════
     CONTACT CTA
════════════════════════════════════════════ -->
<section class="sp" id="contact" style="background:var(--bg2);border-top:1px solid var(--border)">
  <div class="inner contact-grid">
    <div>
      <div class="slabel reveal">Get In Touch</div>
      <h2 class="contact-h reveal d1">Let's start<br>a <em>conversation</em>.</h2>
      <p class="about-p reveal d2" style="margin-bottom:36px">Please submit your contact information and one of our team members will be in touch with you shortly.</p>
      <ul class="cdet reveal d3">
        <li class="cd"><span class="cd-l">Location</span><span class="cd-v">{{ settings | getSetting('location') }}</span></li>
        <li class="cd"><span class="cd-l">Instagram</span><a href="{{ settings | getSetting('instagram_url') }}" target="_blank" class="cd-v">{{ settings | getSetting('instagram_handle') }}</a></li>
        <li class="cd"><span class="cd-l">Facebook</span><a href="{{ settings | getSetting('facebook_url') }}" target="_blank" class="cd-v">{{ settings | getSetting('facebook_label') }}</a></li>
        <li class="cd"><span class="cd-l">LinkedIn</span><a href="{{ settings | getSetting('linkedin_url') }}" target="_blank" class="cd-v">{{ settings | getSetting('linkedin_label') }}</a></li>
      </ul>
    </div>
    <div>
      <form class="cform reveal d1" id="cform">
        <div class="frow">
          <div class="fg"><label class="fl">First Name*</label><input type="text" class="fi" placeholder="First name" required></div>
          <div class="fg"><label class="fl">Last Name*</label><input type="text" class="fi" placeholder="Last name" required></div>
        </div>
