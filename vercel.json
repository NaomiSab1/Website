    { "source": "/properties/sierra.html",  "destination": "/properties/sierra/",  "permanent": true },
    { "source": "/properties/caspian.html", "destination": "/properties/caspian/", "permanent": true },
    { "source": "/properties/capri.html",   "destination": "/properties/capri/",   "permanent": true },
    { "source": "/properties/aether.html",  "destination": "/properties/aether/",  "permanent": true },
    { "source": "/index.html",              "destination": "/",                    "permanent": true }
  ]
