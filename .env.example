# Supabase — copy from your Supabase project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Vercel deploy hook — copy from Vercel project Settings → Git → Deploy Hooks
# The admin "Publish" button calls this URL to trigger a rebuild
VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/your-hook-id
