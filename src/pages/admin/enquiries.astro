---
import Admin from '../../layouts/Admin.astro';
import { supabaseConfigured, getAdminUser, serviceClient } from '../../lib/admin.js';

const user = supabaseConfigured ? await getAdminUser(Astro.cookies) : null;
if (!user) return Astro.redirect('/admin/');

const { data, error } = await serviceClient()
  .from('enquiries')
  .select('*')
  .order('created_at', { ascending: false })
  .limit(200);
const enquiries = data ?? [];

const fmt = (d) =>
  new Intl.DateTimeFormat('en-AU', { dateStyle: 'medium', timeStyle: 'short', timeZone: 'Australia/Brisbane' })
    .format(new Date(d));
---
<Admin title="Enquiries" user={user}>
  <h1>Enquiries</h1>
  {error && <div class="note error">Could not load enquiries: {error.message}</div>}
  {enquiries.length === 0 && !error && <div class="note">No enquiries yet. Submissions from every form on the site will appear here.</div>}
  {enquiries.length > 0 && (
    <table>
      <thead>
        <tr><th>Received</th><th>Form</th><th>Name</th><th>Contact</th><th>Re</th><th>Message</th></tr>
      </thead>
      <tbody>
        {enquiries.map((e) => (
          <tr>
            <td class="muted" style="white-space:nowrap">{fmt(e.created_at)}</td>
            <td class="muted">{e.form_name}</td>
            <td><strong>{[e.first_name, e.last_name].filter(Boolean).join(' ')}</strong>{e.agency && <div class="muted">{e.agency}</div>}</td>
            <td>
              {e.email && <div><a href={`mailto:${e.email}`} style="color:var(--gold)">{e.email}</a></div>}
              {e.phone && <div class="muted">{e.phone}</div>}
            </td>
            <td class="muted">{e.property || e.enquiry_type || '—'}</td>
            <td style="max-width:340px">{e.message}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Admin>
