---
interface Props {
  title: string;
  user?: { email?: string } | null;
}
const { title, user } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="robots" content="noindex, nofollow">
<title>{title} — Sabdia Admin</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<style is:inline>
@import url('https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500&display=swap');
:root{--bg:#F2F0EB;--dark:#0E0D0B;--ink:#1A1814;--ink3:#635F58;--gold:#9E8B6A;--gold2:#C4AC87;--border:rgba(78,73,62,.16);--white:#FDFCF8}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--ink);font-family:'Jost',sans-serif;font-weight:300;line-height:1.6;min-height:100vh}
a{color:inherit;text-decoration:none}
.bar{background:var(--dark);color:var(--white);display:flex;align-items:center;gap:28px;padding:16px 28px;flex-wrap:wrap}
.bar-brand{font-size:13px;letter-spacing:.32em;text-transform:uppercase;font-weight:400}
.bar-brand span{color:var(--gold2)}
.bar nav{display:flex;gap:22px;margin-left:12px}
.bar nav a{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(253,252,248,.65)}
.bar nav a:hover{color:var(--white)}
.bar-right{margin-left:auto;display:flex;align-items:center;gap:16px;font-size:11px;color:rgba(253,252,248,.5)}
.bar-right form{display:inline}
.bar-right button{background:none;border:1px solid rgba(253,252,248,.35);color:rgba(253,252,248,.8);padding:6px 16px;font-family:inherit;font-size:10px;letter-spacing:.18em;text-transform:uppercase;cursor:pointer}
.bar-right button:hover{border-color:var(--white);color:var(--white)}
.wrap{max-width:1100px;margin:0 auto;padding:40px 28px}
h1{font-size:22px;font-weight:400;letter-spacing:.04em;margin-bottom:22px}
.note{padding:12px 18px;border:1px solid var(--gold);background:rgba(158,139,106,.08);font-size:13px;margin-bottom:24px}
.error{border-color:#b3553f;background:rgba(179,85,63,.08)}
table{width:100%;border-collapse:collapse;background:var(--white);font-size:13px}
th{font-size:9.5px;letter-spacing:.22em;text-transform:uppercase;color:var(--ink3);font-weight:400;text-align:left}
th,td{padding:11px 14px;border-bottom:1px solid var(--border);vertical-align:top}
tr:hover td{background:rgba(158,139,106,.05)}
.btn{display:inline-block;background:var(--gold);color:var(--white);border:none;padding:12px 28px;font-family:inherit;font-size:10px;letter-spacing:.24em;text-transform:uppercase;cursor:pointer}
.btn:hover{background:var(--gold2)}
.btn-ghost{background:none;border:1px solid var(--border);color:var(--ink)}
.btn-danger{background:none;border:1px solid #b3553f;color:#b3553f}
.field{margin-bottom:16px}
.field label{display:block;font-size:9.5px;letter-spacing:.24em;text-transform:uppercase;color:var(--ink3);margin-bottom:6px}
.field input,.field select,.field textarea{width:100%;padding:10px 12px;border:1px solid var(--border);background:var(--white);font-family:inherit;font-size:13.5px;font-weight:300;color:var(--ink)}
.field textarea{min-height:90px;resize:vertical}
.field input:focus,.field select:focus,.field textarea:focus{outline:none;border-color:var(--gold)}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:0 20px}
.grid4{display:grid;grid-template-columns:repeat(4,1fr);gap:0 20px}
.row{display:flex;gap:12px;align-items:center;margin-top:24px;flex-wrap:wrap}
.tag{display:inline-block;padding:2px 10px;font-size:9px;letter-spacing:.2em;text-transform:uppercase}
.tag-sale{background:rgba(158,139,106,.15);color:var(--gold)}
.tag-sold{background:rgba(26,24,20,.08);color:var(--ink3)}
.muted{color:var(--ink3);font-size:12px}
@media(max-width:760px){.grid2,.grid4{grid-template-columns:1fr}.wrap{padding:24px 16px}}
</style>
</head>
<body>
<header class="bar">
  <div class="bar-brand">SABDIA <span>Admin</span></div>
  {user && (
    <nav>
      <a href="/admin/">Properties</a>
      <a href="/admin/enquiries/">Enquiries</a>
      <a href="/" target="_blank">View Site ↗</a>
    </nav>
  )}
  <div class="bar-right">
    {user && <span>{user.email}</span>}
    {user && (
      <form method="POST" action="/api/admin/logout">
        <button type="submit">Log out</button>
      </form>
    )}
  </div>
</header>
<main class="wrap">
  <slot />
</main>
</body>
</html>
