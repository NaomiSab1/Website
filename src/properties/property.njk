---
pagination:
  data: properties
  size: 1
  alias: property
layout: base.njk
eleventyComputed:
  title: "{{ property.seo_title or (property.name + ' | Sabdia Constructions') }}"
  description: "{{ property.seo_description or ('Discover ' + property.name + ' by Sabdia Constructions — ' + property.location + '.') }}"
  og_image: "{{ property.hero_image }}"
permalink: "/properties/{{ property.slug }}/"
---

<!-- PROP HERO -->
<section class="prop-hero">
  <img src="{{ property.hero_image }}" alt="{{ property.name }}" loading="eager" style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.48) saturate(.82)">
  <div class="prop-hero-ov"></div>
  <div class="prop-hero-content inner">
    <div class="prop-status">
      {% if property.status == 'for_sale' %}
      <div class="prop-status-dot active"></div>
      <span style="font-size:9.5px;font-weight:300;letter-spacing:.34em;text-transform:uppercase;color:rgba(253,252,248,.6)">For Sale</span>
      {% else %}
      <div class="prop-status-dot"></div>
      <span style="font-size:9.5px;font-weight:300;letter-spacing:.34em;text-transform:uppercase;color:rgba(253,252,248,.4)">Sold Prior to Completion</span>
      {% endif %}
    </div>
    <div class="prop-name">{{ property.name }}</div>
    <div class="prop-loc">{{ property.location }}</div>
  </div>
</section>

<!-- SPECS BAR -->
<div class="prop-specs-bar">
  <div class="prop-specs-inner">
    <div class="prop-spec-item">
      <div class="prop-spec-l">Location</div>
      <div class="prop-spec-v" style="font-size:16px">{{ property.suburb }}</div>
    </div>
    <div class="prop-spec-item">
      <div class="prop-spec-l">Bedrooms</div>
      <div class="prop-spec-v">{{ property.bedrooms }}</div>
    </div>
    <div class="prop-spec-item">
      <div class="prop-spec-l">Bathrooms</div>
      <div class="prop-spec-v">{{ property.bathrooms }}</div>
    </div>
    <div class="prop-spec-item">
      <div class="prop-spec-l">Garages</div>
      <div class="prop-spec-v">{{ property.garages }}</div>
    </div>
    <div class="prop-spec-item">
      <div class="prop-spec-l">Land Size</div>
      <div class="prop-spec-v">{{ property.land_size }}</div>
    </div>
    <div class="prop-spec-item">
      <div class="prop-spec-l">Status</div>
      <div class="prop-spec-v" style="font-size:16px;color:var(--gold2)">{{ "For Sale" if property.status == "for_sale" else "Sold" }}</div>
    </div>
  </div>
</div>

<!-- BODY -->
<div class="prop-body">
  <div class="prop-layout inner">
    <div class="prop-desc">
      <div class="slabel prop-desc-slabel reveal">About {{ property.name }}</div>
      <h1 class="prop-body-h reveal d1">{{ property.tagline | safe }}</h1>

      {% if property.description_paragraphs %}
        {% for para in property.description_paragraphs %}
        <p class="prop-body-p reveal d2">{{ para }}</p>
        {% endfor %}
      {% elif property.description %}
        {% for para in property.description.split('\n\n') %}
        <p class="prop-body-p reveal d2">{{ para }}</p>
        {% endfor %}
      {% endif %}

      {% if property.features and property.features | length > 0 %}
      <div class="prop-features reveal d3">
        <div class="prop-features-h">Key Features</div>
        <div class="prop-feat-grid">
          {% for feat in property.features %}
          <div class="prop-feat">{{ feat }}</div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>

    <div class="reveal d2">
      <div class="prop-enquire">
        <div class="prop-enquire-h">Enquire About {{ property.name }}</div>
        <p style="font-size:13px;font-weight:300;color:var(--ink3);line-height:1.75;margin-bottom:24px">Register your interest or arrange a private inspection. Our team will be in touch within one business day.</p>
        <form class="cform" id="cform">
          <div class="frow">
            <div class="fg"><label class="fl">First Name*</label><input type="text" class="fi" placeholder="First name" required></div>
            <div class="fg"><label class="fl">Last Name*</label><input type="text" class="fi" placeholder="Last name" required></div>
          </div>
          <div class="fg"><label class="fl">Email*</label><input type="email" class="fi" placeholder="Email address" required></div>
          <div class="fg"><label class="fl">Phone</label><input type="tel" class="fi" placeholder="Phone number"></div>
          <div class="fg">
            <label class="fl">Enquiry Type</label>
            <select class="fsel">
              <option>Register Interest</option>
              <option>Arrange Private Inspection</option>
              <option>Request Price Guide</option>
              <option>General Enquiry</option>
            </select>
          </div>
          <div class="fg"><label class="fl">Message</label><textarea class="fta" placeholder="Tell us about your requirements or any questions you have…"></textarea></div>
          <p class="form-note">By submitting this form you agree to our privacy policy. Your details will not be shared with third parties.</p>
          <button type="submit" class="fsub" id="fsub">Submit Enquiry &rarr;</button>
        </form>
      </div>
      <div style="margin-top:16px;display:flex;flex-direction:column;gap:10px">
        <a href="/contact.html" class="btn-g btn-g-gold" style="justify-content:center">General Enquiry</a>
      </div>
    </div>
  </div>
</div>

<!-- GALLERY -->
{% if property.gallery_images and property.gallery_images | length > 0 %}
<div class="prop-gallery inner">
  <div class="slabel reveal" style="margin-bottom:28px">Gallery</div>
  <div class="prop-gallery-grid">
    {% for img in property.gallery_images %}
    <div class="gallery-item gallery-{{ ['a','b','c','d','e','f'][loop.index0] }} reveal{% if not loop.first %} d{{ loop.index0 }}{% endif %}">
      <img class="gallery-img" src="{{ img.url }}" alt="{{ img.alt }}" loading="lazy">
    </div>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- RELATED PROPERTIES -->
{% set otherProps = properties | excludeSlug(property.slug) %}
{% if otherProps | length > 0 %}
<div class="prop-related inner">
  <h2 class="prop-related-h reveal">Explore more <em>Sabdia residences</em></h2>
  <div class="prop-related-grid">
    {% for rel in otherProps %}
    <a href="/properties/{{ rel.slug }}/" class="pc reveal{% if not loop.first %} d{{ loop.index - 1 }}{% endif %}" style="aspect-ratio:4/3">
      <img src="{{ rel.card_image }}" alt="{{ rel.name }}" loading="lazy">
      <div class="pc-ov"></div>
      <div class="pc-info">
        <div class="pc-status"><div class="pc-dot"></div>{{ "For Sale" if rel.status == "for_sale" else "Sold" }}</div>
        <div class="pc-name">{{ rel.name }}</div>
        <div class="pc-loc">{{ rel.suburb }}, QLD</div>
        <div class="pc-specs">
          <span class="pc-spec">{{ rel.bedrooms }} Bed</span>
          <span class="pc-spec">{{ rel.bathrooms }} Bath</span>
          <span class="pc-spec">{{ rel.garages }} Car</span>
        </div>
      </div>
      <div class="pc-arrow">&rarr;</div>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}
