<footer>
  <div class="footer-tagline">
    <div class="footer-tagline-inner">
      <h2 class="footer-tag-h">Design. <em>Develop.</em><br>Construct.</h2>
      <p class="footer-tag-sub">{{ settings | getSetting('footer_tagline') }}</p>
    </div>
  </div>
  <div class="fg-grid">
    <div>
      <a href="/" class="flogo">
        <img src="https://static.wixstatic.com/media/1cc2db_f012027bbf0c45ebb4ae6d847309d59f~mv2.png/v1/fill/w_211,h_35,al_c,q_85,usm_0.66_1.00_0.01,enc_avif,quality_auto/DESIGN%20%C2%B7%20DEVELOP%20%C2%B7%20CONSTRUCT.png" alt="Sabdia Constructions">
      </a>
      <p class="ftag">Boutique Luxury Home Builder &amp;<br>Developer — Brisbane, QLD</p>
      <div class="fsoc">
        <a href="{{ settings | getSetting('instagram_url') }}" target="_blank" class="fsl" aria-label="Instagram">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        </a>
        <a href="{{ settings | getSetting('facebook_url') }}" target="_blank" class="fsl" aria-label="Facebook">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="{{ settings | getSetting('linkedin_url') }}" target="_blank" class="fsl" aria-label="LinkedIn">
          <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
      </div>
    </div>
    <div>
      <div class="fct">For Sale</div>
      <ul class="fcl">
        {% for prop in properties | forSale %}
        <li><a href="/properties/{{ prop.slug }}/">{{ prop.name }} — {{ prop.suburb }}</a></li>
        {% endfor %}
        <li><a href="/properties/">View All Properties</a></li>
      </ul>
    </div>
    <div>
      <div class="fct">Company</div>
      <ul class="fcl">
        <li><a href="/about.html">About Sabdia</a></li>
        <li><a href="/services.html">Services</a></li>
        <li><a href="/projects.html">Projects</a></li>
        <li><a href="/collection.html">Collection</a></li>
        <li><a href="/agent-access.html">Agent Access</a></li>
      </ul>
    </div>
    <div>
      <div class="fct">Connect</div>
      <ul class="fcl">
        <li><a href="/contact.html">Contact Us</a></li>
        <li><a href="{{ settings | getSetting('instagram_url') }}" target="_blank">Instagram {{ settings | getSetting('instagram_handle') }}</a></li>
        <li><a href="{{ settings | getSetting('facebook_url') }}" target="_blank">Facebook</a></li>
        <li><a href="{{ settings | getSetting('linkedin_url') }}" target="_blank">LinkedIn</a></li>
        <li><a href="{{ settings | getSetting('website_url') }}" target="_blank">sabdiaconstructions.com.au</a></li>
      </ul>
    </div>
  </div>
  <div class="fbot">
    <div class="fcopy">&copy; {{ settings | getSetting('copyright_year') }} {{ settings | getSetting('company_name') }}. All rights reserved.</div>
    <div class="flinks">
      <a href="/contact.html">Accessibility</a>
      <a href="/contact.html">Privacy Policy</a>
    </div>
  </div>
</footer>
