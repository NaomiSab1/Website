---
layout: base.njk
title: "Properties For Sale | Sabdia Constructions"
description: "Luxury properties for sale by Sabdia Constructions — Brisbane's award-winning boutique luxury home builder. Discover QASR, SOLACE, SIERRA, and CASPIAN."
permalink: /properties/
---

{% set forSaleProps = properties | forSale %}
{% set soldProps = properties | sold %}
{% set featuredProp = properties | featured %}

<!-- PAGE HEADER -->
<section style="padding:clamp(130px,18vw,180px) clamp(22px,5vw,80px) clamp(48px,6vw,72px);background:var(--bg);border-bottom:1px solid var(--border)">
  <div class="inner" style="display:flex;align-items:flex-end;justify-content:space-between;gap:40px;flex-wrap:wrap">
    <div>
      <div class="slabel reveal" style="margin-bottom:18px">For Sale</div>
      <h1 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(48px,9vw,120px);font-weight:300;line-height:.88;letter-spacing:-.035em;color:var(--ink)"><em style="color:var(--gold)">Current</em><br>Properties.</h1>
    </div>
    <p class="reveal d2" style="font-size:13.5px;font-weight:300;line-height:1.9;color:var(--ink3);max-width:380px;padding-bottom:6px">{{ forSaleProps | length }} extraordinary {{ "residence" if forSaleProps | length == 1 else "residences" }} across Brisbane's most sought-after inner suburbs — each designed, developed, and built entirely in-house by Sabdia.</p>
  </div>
</section>

<!-- FEATURED HERO CARD -->
{% if featuredProp %}
<section style="padding:clamp(40px,5vw,64px) clamp(22px,5vw,80px) 0;background:var(--bg)">
  <div class="inner">
    <a href="/properties/{{ featuredProp.slug }}/" class="reveal" style="display:block;position:relative;overflow:hidden;height:clamp(400px,52vw,680px);cursor:none;text-decoration:none">
      <img src="{{ featuredProp.hero_image }}"
           alt="{{ featuredProp.name }}" loading="eager"
           style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.82) saturate(.88);transition:filter .7s,transform .7s">
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(14,13,11,.88) 0%,rgba(14,13,11,.1) 50%,transparent 100%);transition:opacity .4s"></div>
      <div style="position:absolute;bottom:0;left:0;right:0;padding:clamp(28px,4vw,52px)">
        <div style="display:inline-flex;align-items:center;gap:6px;margin-bottom:10px">
          <div style="width:5px;height:5px;border-radius:50%;background:var(--gold2);animation:pulse 2s ease-in-out infinite;flex-shrink:0"></div>
          <span style="font-size:9px;font-weight:300;letter-spacing:.3em;text-transform:uppercase;color:var(--gold2)">For Sale</span>
        </div>
        <div style="font-family:var(--font-d);font-size:clamp(44px,8vw,110px);font-weight:300;line-height:.88;letter-spacing:-.04em;color:var(--white);margin-bottom:10px">{{ featuredProp.name }}</div>
        <div style="font-size:11px;font-weight:300;letter-spacing:.22em;text-transform:uppercase;color:rgba(253,252,248,.5);margin-bottom:18px">{{ featuredProp.location }}</div>
        <div style="display:flex;gap:18px;flex-wrap:wrap">
          <span style="font-size:10px;font-weight:300;letter-spacing:.08em;color:rgba(253,252,248,.6)">{{ featuredProp.bedrooms }} Bed</span>
          <span style="font-size:10px;color:rgba(253,252,248,.25)">&middot;</span>
          <span style="font-size:10px;font-weight:300;letter-spacing:.08em;color:rgba(253,252,248,.6)">{{ featuredProp.bathrooms }} Bath</span>
          <span style="font-size:10px;color:rgba(253,252,248,.25)">&middot;</span>
          <span style="font-size:10px;font-weight:300;letter-spacing:.08em;color:rgba(253,252,248,.6)">{{ featuredProp.garages }} Garage</span>
          <span style="font-size:10px;color:rgba(253,252,248,.25)">&middot;</span>
          <span style="font-size:10px;font-weight:300;letter-spacing:.08em;color:rgba(253,252,248,.6)">{{ featuredProp.land_size }}</span>
        </div>
      </div>
      <div style="position:absolute;top:clamp(18px,3vw,32px);right:clamp(18px,3vw,32px);width:44px;height:44px;border:1px solid rgba(196,172,135,.45);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--gold2);font-size:16px">&rarr;</div>
    </a>
  </div>
</section>
{% endif %}

<!-- REMAINING FOR-SALE PROPERTIES -->
{% if forSaleProps | length > 1 %}
<section style="padding:clamp(8px,1vw,10px) clamp(22px,5vw,80px) 0;background:var(--bg)">
  <div class="inner">
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
      {% for prop in forSaleProps %}
      {% if not prop.is_featured %}
      <a href="/properties/{{ prop.slug }}/" class="pc reveal{% if loop.index > 1 %} d{{ loop.index - 1 }}{% endif %}" style="aspect-ratio:16/10">
        <img src="{{ prop.card_image_sm or prop.card_image }}" alt="{{ prop.name }}" loading="lazy">
        <div class="pc-ov"></div>
        <div class="pc-info">
          <div class="pc-status"><div class="pc-dot"></div>For Sale</div>
          <div class="pc-name">{{ prop.name }}</div>
          <div class="pc-loc">{{ prop.suburb }}, QLD</div>
          <div class="pc-specs">
            <span class="pc-spec">{{ prop.bedrooms }} Bed</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ prop.bathrooms }} Bath</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ prop.garages }} Garage</span><span class="pc-spec">&middot;</span>
            <span class="pc-spec">{{ prop.land_size }}</span>
          </div>
        </div>
        <div class="pc-arrow">&rarr;</div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- SOLD SECTION -->
{% if soldProps | length > 0 %}
<section style="padding:clamp(64px,8vw,100px) clamp(22px,5vw,80px) clamp(80px,10vw,120px);background:var(--bg)">
  <div class="inner">
    <div class="slabel reveal" style="margin-bottom:32px">Sold Prior to Completion</div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px">
      {% for prop in soldProps %}
      <a class="sc-card reveal{% if not loop.first %} d1{% endif %}" href="/properties/{{ prop.slug }}/">
        <img src="{{ prop.card_image_sm or prop.card_image }}" alt="{{ prop.name }}" loading="lazy">
        <div class="sc-ov"></div>
        <div class="sc-badge">Sold Prior to Completion</div>
        <div class="sc-info">
          <div class="sc-name">{{ prop.name }}</div>
          <div class="sc-loc">{{ prop.suburb }}, QLD &middot; {{ prop.bedrooms }} Bed &middot; {{ prop.bathrooms }} Bath &middot; {{ prop.garages }} Garage &middot; {{ prop.land_size }}</div>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- ENQUIRE CTA -->
<section class="sp" style="background:var(--bg2);border-top:1px solid var(--border);text-align:center">
  <div class="inner-sm">
    <div class="slabel reveal" style="justify-content:center;margin-bottom:20px">Private Enquiry</div>
    <h2 class="reveal d1" style="font-family:var(--font-d);font-size:clamp(32px,5vw,64px);font-weight:300;color:var(--ink);margin-bottom:20px;letter-spacing:-.02em">Interested in a<br><em style="color:var(--gold)">private viewing</em>?</h2>
    <p class="reveal d2" style="font-size:13px;font-weight:300;color:var(--ink3);max-width:420px;margin:0 auto 36px;line-height:1.85">We offer private, exclusive viewings for serious buyers. Contact us to arrange an inspection at a time that suits you.</p>
    <div class="reveal d3" style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
      <a href="/contact.html" class="btn-p">Request a Viewing &rarr;</a>
      <a href="/agent-access.html" class="btn-g">Agent Enquiries</a>
    </div>
  </div>
</section>
