# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL + anon key: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — SERVER ONLY. Never expose to the browser.
# Used for: form submission inserts, on-demand revalidation endpoint.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Site ──────────────────────────────────────────────────────────────────
# Canonical public URL (used for sitemap, OG tags, structured data)
NEXT_PUBLIC_SITE_URL=https://www.sabdiaconstructions.com.au

# Shared secret for POST /api/revalidate (external cache busting)
REVALIDATE_SECRET=change-me-to-a-long-random-string

# ── Lead forwarding (optional — leave blank to disable) ───────────────────
# Monday.com (or any) webhook that receives each form submission as JSON
LEADS_WEBHOOK_URL=

# Resend API key + destination for email notifications of new leads
RESEND_API_KEY=
LEADS_NOTIFY_EMAIL=info@sabdiaconstructions.com.au
LEADS_FROM_EMAIL=website@sabdiaconstructions.com.au
