---
import Admin from '../../../layouts/Admin.astro';
import { supabaseConfigured, getAdminUser, serviceClient } from '../../../lib/admin.js';

const user = supabaseConfigured ? await getAdminUser(Astro.cookies) : null;
if (!user) return Astro.redirect('/admin/');

const { slug } = Astro.params;
const isNew = slug === 'new';

let p = null;
if (!isNew) {
  const { data } = await serviceClient().from('properties').select('*').eq('slug', slug).maybeSingle();
  if (!data) return Astro.redirect('/admin/');
  p = data;
}

const featuresText = p ? (p.features ?? []).join('\n') : '';
const galleryText = p ? (p.gallery ?? []).map((g) => `${g.src} | ${g.alt ?? ''}`).join('\n') : '';
const err = Astro.url.searchParams.get('error');
---
<Admin title={isNew ? 'Add Property' : `Edit ${p.name}`} user={user}>
  <h1>{isNew ? 'Add Property' : `Edit ${p.name}`}</h1>
  {err && <div class="note error">Could not save: {err}</div>}

  <form method="POST" action="/api/admin/save-property">
    <input type="hidden" name="original-slug" value={isNew ? '' : p.slug}>

    <div class="grid2">
      <div class="field">
        <label for="name">Name</label>
        <input id="name" name="name" required value={p?.name ?? ''} placeholder="e.g. MARLOW">
      </div>
      <div class="field">
        <label for="slug">URL slug (lowercase, no spaces)</label>
        <input id="slug" name="slug" required value={p?.slug ?? ''} placeholder="e.g. marlow" pattern="[a-z0-9-]+">
      </div>
    </div>

    <div class="grid4">
      <div class="field">
        <label for="status">Status</label>
        <select id="status" name="status">
          <option value="for-sale" selected={!p || p.status === 'for-sale'}>For Sale</option>
          <option value="sold" selected={p?.status === 'sold'}>Sold Prior to Completion</option>
        </select>
      </div>
      <div class="field">
        <label for="display_order">Display order</label>
        <input id="display_order" name="display_order" type="number" value={p?.display_order ?? 10} required>
      </div>
      <div class="field">
        <label for="suburb">Suburb</label>
        <input id="suburb" name="suburb" required value={p?.suburb ?? ''}>
      </div>
      <div class="field">
        <label for="year">Year</label>
        <input id="year" name="year" type="number" value={p?.year ?? new Date().getFullYear()}>
      </div>
    </div>

    <div class="grid4">
      <div class="field">
        <label for="beds">Bedrooms</label>
        <input id="beds" name="beds" type="number" value={p?.beds ?? 5} required>
      </div>
      <div class="field">
        <label for="baths">Bathrooms</label>
        <input id="baths" name="baths" type="number" value={p?.baths ?? 5} required>
      </div>
      <div class="field">
        <label for="cars">Garages</label>
        <input id="cars" name="cars" type="number" value={p?.cars ?? 3} required>
      </div>
      <div class="field">
        <label for="land">Land (m²)</label>
        <input id="land" name="land" type="number" value={p?.land ?? 600} required>
      </div>
    </div>

    <div class="field">
      <label for="land_over" style="display:flex;align-items:center;gap:8px;text-transform:none;letter-spacing:.02em;font-size:13px">
        <input id="land_over" name="land_over" type="checkbox" style="width:auto" checked={p?.land_over}>
        Land size is a minimum (shows as "m²+")
      </label>
    </div>

    <div class="field">
      <label for="image">Hero image URL</label>
      <input id="image" name="image" required value={p?.image ?? ''} placeholder="https://…">
    </div>
    <div class="grid2">
      <div class="field">
        <label for="focus">Image focal point (optional, e.g. fp_0.5_0.65)</label>
        <input id="focus" name="focus" value={p?.focus ?? ''}>
      </div>
      <div class="field">
        <label for="headline">Headline (may contain &lt;br&gt; and &lt;em&gt;)</label>
        <input id="headline" name="headline" required value={p?.headline ?? ''}>
      </div>
    </div>

    <div class="field">
      <label for="seo_description">SEO description</label>
      <textarea id="seo_description" name="seo_description">{p?.seo_description ?? ''}</textarea>
    </div>

    <div class="field">
      <label for="description">Description (one paragraph per blank line)</label>
      <textarea id="description" name="description" style="min-height:180px">{p?.description ?? ''}</textarea>
    </div>

    <div class="grid2">
      <div class="field">
        <label for="features">Key features (one per line)</label>
        <textarea id="features" name="features" style="min-height:180px">{featuresText}</textarea>
      </div>
      <div class="field">
        <label for="gallery">Gallery images (one per line: URL | alt text)</label>
        <textarea id="gallery" name="gallery" style="min-height:180px">{galleryText}</textarea>
      </div>
    </div>

    <div class="grid2">
      <div class="field">
        <label for="enquiry_heading">Enquiry box heading</label>
        <input id="enquiry_heading" name="enquiry_heading" value={p?.enquiry_heading ?? 'Enquire About This Residence'}>
      </div>
      <div class="field">
        <label for="enquiry_button">Enquiry button label</label>
        <input id="enquiry_button" name="enquiry_button" value={p?.enquiry_button ?? 'Submit Enquiry'}>
      </div>
    </div>
    <div class="field">
      <label for="enquiry_text">Enquiry box text</label>
      <textarea id="enquiry_text" name="enquiry_text">{p?.enquiry_text ?? 'Register your interest or arrange a private inspection. Our team will be in touch within one business day.'}</textarea>
    </div>

    <div class="row">
      <button type="submit" class="btn">{isNew ? 'Create Property' : 'Save Changes'}</button>
      <a href="/admin/" class="btn btn-ghost">Cancel</a>
      {!isNew && <a href={`/properties/${p.slug}/`} target="_blank" class="btn btn-ghost">View Page ↗</a>}
    </div>
  </form>

  {!isNew && (
    <form method="POST" action="/api/admin/delete-property" style="margin-top:40px;padding-top:24px;border-top:1px solid var(--border)"
          onsubmit="return confirm('Delete this property? This cannot be undone.')">
      <input type="hidden" name="slug" value={p.slug}>
      <button type="submit" class="btn btn-danger">Delete Property</button>
    </form>
  )}
</Admin>
